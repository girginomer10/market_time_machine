{
  "name": "market-time-machine",
  "version": "0.2.0",
  "description": "Open source financial history lab for replaying past markets without seeing the future",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/girginomer10/market_time_machine.git"
  },
  "bugs": {
    "url": "https://github.com/girginomer10/market_time_machine/issues"
  },
  "homepage": "https://github.com/girginomer10/market_time_machine#readme",
  "keywords": [
    "market-replay",
    "trading-simulator",
    "financial-history",
    "scenario-simulation",
    "react",
    "typescript",
    "vite"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "import:fred-sp500": "node scripts/import-fred-sp500.mjs",
    "import:ecb-eurgbp": "node scripts/import-ecb-eurgbp.mjs",
    "import:ohlcv": "node scripts/import-local-ohlcv.mjs",
    "check": "npm run lint && npm run test && npm run build && npm run check:bundle-license && npm run check:pwa",
    "check:bundle-license": "node scripts/check-production-bundle.mjs",
    "check:pwa": "node --check public/sw.js && node -e \"const fs=require('node:fs'); JSON.parse(fs.readFileSync('public/manifest.webmanifest','utf8')); ['public/icons/icon-192.png','public/icons/icon-512.png','public/icons/icon-maskable-512.png'].forEach((file)=>fs.accessSync(file));\"",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lightweight-charts": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
